# Copiar este contenido en Streamlit Cloud > App settings > Secrets.
# No subir el archivo secrets.toml real a GitHub.

[drive]
stock_file_id = "1D4gde-bbWlPw910hxaVQidpfIULShhS8"
# Completar cuando subas/identifiques el JSON de imágenes en Drive.
images_index_file_id = ""
# Google Sheet oficial de reglas. Si falla, usa la planilla incluida en GitHub.
rules_file_id = "10kmGyYwpE4f-ujUgAigwDrQ7uS5DQHs_jQYxcFDNDQc"

[freshness]
timezone = "America/Argentina/Buenos_Aires"
# Durante horario abierto, bloquea si el CSV supera esta antigüedad.
max_age_minutes_open = 120
# Fuera de horario puede seguir disponible durante sábado/domingo o cierres.
max_age_hours_closed = 72
# 0=lunes ... 6=domingo. Ajustable.
open_weekdays = [0, 1, 2, 3, 4, 5]
open_ranges = ["09:00-13:00", "14:30-19:30"]

[app]
discount_percent = 5
whatsapp_number = "54911XXXXXXXX"

# Recomendado para archivos privados. Compartí la carpeta/archivo con client_email como lector.
[google_service_account]
type = "service_account"
project_id = ""
private_key_id = ""
private_key = """-----BEGIN PRIVATE KEY-----
PEGAR_CLAVE
-----END PRIVATE KEY-----"""
client_email = ""
client_id = ""
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = ""
